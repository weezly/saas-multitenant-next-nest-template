# Next.js App Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Dynamic Authentication Providers
# Syntax: credentials,google,github,microsoft
# Nur aktivierte Provider werden geladen
AUTH_PROVIDERS=credentials,google,github

# OAuth Provider: Google
# 1. Gehe zu: https://console.cloud.google.com
# 2. Erstelle "OAuth 2.0 Client ID" (Web Application)
# 3. Setze Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Provider: GitHub
# 1. Gehe zu: https://github.com/settings/developers
# 2. Erstelle "OAuth App"
# 3. Setze Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth Provider: Microsoft Azure AD (optional)
# 1. Gehe zu: https://portal.azure.com
# 2. Registriere "Application" in Azure AD
# 3. Setze Redirect URI: http://localhost:3000/api/auth/callback/microsoft
# 4. Erstelle "Client Secret"
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

